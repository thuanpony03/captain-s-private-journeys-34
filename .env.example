# Supabase — lấy tại Dashboard → Project Settings → API
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Site URL dùng cho canonical, OG tag và sitemap (không có dấu / ở cuối)
VITE_SITE_URL=https://vinharound.com

# Để "true" mới hiện tab đăng ký ở /auth. Mặc định TẮT —
# xem chú thích trong src/pages/Auth.tsx trước khi bật.
VITE_ALLOW_PUBLIC_SIGNUP=false

# ---------------------------------------------------------------------------
# Chỉ dùng cho script sinh sitemap (scripts/generate-sitemap.mjs), không đưa
# vào bundle client. Có thể bỏ trống — script sẽ tự fallback về VITE_*.
# ---------------------------------------------------------------------------
SITE_URL=https://vinharound.com
