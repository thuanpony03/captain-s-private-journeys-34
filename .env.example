# ---------------------------------------------------------------------------
# Supabase — Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
# Dùng cho canonical, OG tag, sitemap. Không có dấu "/" ở cuối.
NEXT_PUBLIC_SITE_URL=https://vinharound.com

# Để "true" mới hiện tab đăng ký ở /auth. Mặc định TẮT —
# xem chú thích trong src/components/auth/AuthForm.tsx trước khi bật.
NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false

# ---------------------------------------------------------------------------
# Analytics — bỏ trống thì script không được nhúng
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=G-BF2K8J3Y2Z
NEXT_PUBLIC_FB_PIXEL_ID=676642742084121
# Google Tag Manager container (GTM-XXXXXXX) — tuỳ chọn, bỏ trống nếu chưa có.
NEXT_PUBLIC_GTM_ID=
